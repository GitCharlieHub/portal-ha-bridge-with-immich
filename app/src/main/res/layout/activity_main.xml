<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1c1c1c"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_back"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="← Back"
                android:backgroundTint="#333333"
                android:textColor="#ffffff"
                android:layout_marginEnd="12dp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Settings"
                android:textColor="#ffffff"
                android:textSize="20sp"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Status & Permissions -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Status &amp; Permissions"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#252525"
            android:fontFamily="monospace"
            android:textColor="#cccccc"
            android:textSize="12sp"
            android:padding="10dp"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_grant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Grant next missing permission"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- MQTT Broker -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="MQTT Broker"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/et_host"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Broker host"
                android:inputType="textUri"
                android:textColor="#ffffff"
                android:textColorHint="#666666"
                android:backgroundTint="#555555"
                android:layout_marginEnd="8dp" />

            <EditText
                android:id="@+id/et_port"
                android:layout_width="80dp"
                android:layout_height="wrap_content"
                android:hint="Port"
                android:inputType="number"
                android:textColor="#ffffff"
                android:textColorHint="#666666"
                android:backgroundTint="#555555" />

        </LinearLayout>

        <EditText
            android:id="@+id/et_user"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Username (optional)"
            android:inputType="textNoSuggestions"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:backgroundTint="#555555"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_pass"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Password (optional)"
            android:inputType="textPassword"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:backgroundTint="#555555"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/et_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Device name in HA (e.g. Portal)"
            android:inputType="textNoSuggestions"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:backgroundTint="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Home Assistant Dashboard URL -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Home Assistant Dashboard"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <EditText
            android:id="@+id/et_ha_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="http://homeassistant.local:8123/lovelace/portal"
            android:inputType="textUri"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:backgroundTint="#555555"
            android:layout_marginBottom="16dp" />

        <!-- ImmichFrame Photo Slideshow -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="ImmichFrame Photo Slideshow"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Show photos as foreground"
                android:textColor="#cccccc"
                android:textSize="14sp" />

            <Switch
                android:id="@+id/sw_immich_enabled"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content" />

        </LinearLayout>

        <EditText
            android:id="@+id/et_immich_url"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="ImmichFrame URL (e.g. http://192.168.1.10:3000)"
            android:inputType="textUri"
            android:textColor="#ffffff"
            android:textColorHint="#666666"
            android:backgroundTint="#555555"
            android:layout_marginBottom="16dp" />

        <!-- Tap / Tilt Sensitivity -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tap / Tilt Sensitivity"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <TextView
            android:id="@+id/tv_sensitivity_value"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#cccccc"
            android:textSize="13sp"
            android:layout_marginBottom="4dp" />

        <SeekBar
            android:id="@+id/seek_sensitivity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="26"
            android:layout_marginBottom="16dp" />

        <!-- Sub-feature pages -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Feature Settings"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <Button
            android:id="@+id/btn_camera_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Camera &amp; Streaming"
            android:backgroundTint="#1a237e"
            android:layout_marginBottom="8dp" />

        <Button
            android:id="@+id/btn_display_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Display &amp; Presence"
            android:backgroundTint="#1a237e"
            android:layout_marginBottom="16dp" />

        <!-- Save -->
        <Button
            android:id="@+id/btn_save"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save &amp; Restart Service"
            android:backgroundTint="#1B5E20"
            android:layout_marginBottom="16dp" />

        <!-- Manual screen control -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Screen Control"
            android:textColor="#aaaaaa"
            android:textSize="13sp"
            android:textAllCaps="true"
            android:layout_marginBottom="6dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="8dp">

            <Button
                android:id="@+id/btn_sleep"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Sleep"
                android:backgroundTint="#B71C1C"
                android:layout_marginEnd="8dp" />

            <Button
                android:id="@+id/btn_wake"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Wake"
                android:backgroundTint="#1B5E20" />

        </LinearLayout>

        <Button
            android:id="@+id/btn_accessibility"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Enable Accessibility Service"
            android:backgroundTint="#333333"
            android:layout_marginBottom="16dp" />

    </LinearLayout>

</ScrollView>
