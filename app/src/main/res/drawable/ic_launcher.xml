<?xml version="1.0" encoding="utf-8"?>
<!--
    App launcher icon: a simple house silhouette representing a Home Assistant
    bridge. Used as android:icon in the manifest.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Background circle -->
    <path
        android:fillColor="#1B5E20"
        android:pathData="M54,54 m-54,0 a54,54 0 1,0 108,0 a54,54 0 1,0 -108,0" />

    <!-- House body -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M54,22 L22,50 L30,50 L30,84 L48,84 L48,66 L60,66 L60,84 L78,84 L78,50 L86,50 Z" />

    <!-- WiFi/connection arc overlay (top-right of house) -->
    <path
        android:fillColor="#1B5E20"
        android:pathData="M68,32 Q78,32 78,42 Q68,42 68,32 Z"
        android:strokeColor="#A5D6A7"
        android:strokeWidth="2" />

</vector>
