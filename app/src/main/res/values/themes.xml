<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Dark, no-action-bar theme. The Portal runs Android 9/10; Theme.Material3
        and WindowCompat aren't available, so we extend Theme.AppCompat directly.
    -->
    <style name="Theme.PortalHA" parent="Theme.AppCompat.NoActionBar">
        <item name="android:windowBackground">@color/dark_bg</item>
        <item name="android:colorBackground">@color/dark_bg</item>
        <item name="colorPrimary">@color/accent_green</item>
        <item name="colorPrimaryDark">@color/dark_bg</item>
        <item name="colorAccent">@color/accent_green</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        <!-- Remove window title bar and status bar -->
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
